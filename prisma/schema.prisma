generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Empresa {
  id                Int                @id @default(autoincrement())
  nome              String             @unique
  cnpj              String?
  logo              String?
  ativo             Boolean            @default(true)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  unidades          Unidade[]
  usuarios          Usuario[]
  equipamentos      Equipamento[]
  projetos          Projeto[]
  chamados          Chamado[]
  solicitacoes      SolicitacaoAtivo[]

  @@map("empresas")
}

model Projeto {
  id           Int           @id @default(autoincrement())
  nome         String
  descricao    String?
  ativo        Boolean       @default(true)
  dataInicio   DateTime?     @map("data_inicio")
  dataFim      DateTime?     @map("data_fim")
  empresaId    Int           @map("empresa_id")
  empresa      Empresa       @relation(fields: [empresaId], references: [id])
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  equipamentos  Equipamento[]
  usuarios      Usuario[]
  vinculacoes   Vinculacao[]
  logAcessos    LogAcesso[]
  solicitacoes  SolicitacaoAtivo[]

  @@map("projetos")
}

model Unidade {
  id                   Int                    @id @default(autoincrement())
  nome                 String
  cidade               String?
  estado               String?
  empresaId            Int                    @map("empresa_id")
  empresa              Empresa                @relation(fields: [empresaId], references: [id])
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  usuarios             Usuario[]
  equipamentos         Equipamento[]
  solicitacoes         SolicitacaoAtivo[]
  historicoLocAnterior HistoricoLocalizacao[] @relation("HistoricoLocAnterior")
  historicoLocNova     HistoricoLocalizacao[] @relation("HistoricoLocNova")

  @@unique([nome, empresaId])
  @@map("unidades")
}

model Usuario {
  id          Int          @id @default(autoincrement())
  nome        String
  email       String?
  funcao      String?
  role        String       @default("TECNICO")
  senha       String?
  resetToken        String?   @map("reset_token")
  resetTokenExpira  DateTime? @map("reset_token_expira")
  ativo       Boolean      @default(true)
  unidadeId   Int?         @map("unidade_id")
  empresaId   Int          @map("empresa_id")
  projetoId   Int?         @map("projeto_id")
  unidade     Unidade?     @relation(fields: [unidadeId], references: [id])
  empresa     Empresa      @relation(fields: [empresaId], references: [id])
  projeto     Projeto?     @relation(fields: [projetoId], references: [id])
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  vinculacoes          Vinculacao[]
  historicos           Historico[]
  chamados             Chamado[]
  equipamentosTecnico  Equipamento[]    @relation("TecnicoEquipamentos")
  atribuicoesTecnico   Vinculacao[]     @relation("TecnicoAtribuicoes")
  historicoLocalizacao HistoricoLocalizacao[]
  solicitacoesTecnico  SolicitacaoAtivo[] @relation("TecnicoSolicitacoes")

  @@map("usuarios")
}

model Equipamento {
  id                   Int          @id @default(autoincrement())
  tipo                 String?
  marca                String?
  modelo               String?
  serialNumber         String?      @map("serial_number")
  patrimonio           String?
  status               String       @default("DISPONIVEL")
  statusProcesso       String?      @default("Novo") @map("status_processo")
  checklistPreparacao  String?      @map("checklist_preparacao")
  checklistEntrega     String?      @map("checklist_entrega")
  historicoEtapas      String?      @map("historico_etapas")
  agendamento          String?
  tecnicoId            Int?         @map("tecnico_id")
  dataEntrega          DateTime?    @map("data_entrega")
  observacao           String?
  qrCode               String?      @map("qr_code")
  foto                 String?
  dataGarantia         DateTime?    @map("data_garantia")
  unidadeId            Int?         @map("unidade_id")
  empresaId            Int          @map("empresa_id")
  projetoId            Int?         @map("projeto_id")
  unidade              Unidade?     @relation(fields: [unidadeId], references: [id])
  empresa              Empresa      @relation(fields: [empresaId], references: [id])
  projeto              Projeto?     @relation(fields: [projetoId], references: [id])
  tecnico              Usuario?     @relation("TecnicoEquipamentos", fields: [tecnicoId], references: [id])
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  vinculacoes          Vinculacao[]
  historicos           Historico[]
  chamados             Chamado[]
  historicoLocalizacao HistoricoLocalizacao[]
  solicitacoes         SolicitacaoAtivo[]

  @@map("equipamentos")
}

model Vinculacao {
  id              Int         @id @default(autoincrement())
  usuarioId       Int         @map("usuario_id")
  equipamentoId   Int         @map("equipamento_id")
  tecnicoId       Int?        @map("tecnico_id")
  projetoId       Int?        @map("projeto_id")
  dataInicio      DateTime    @default(now()) @map("data_inicio")
  dataFim         DateTime?   @map("data_fim")
  ativa           Boolean     @default(true)
  observacao      String?
  numeroChamado   String?     @map("numero_chamado")
  tipoOperacao    String?     @default("Máquina nova e usuário novo") @map("tipo_operacao")
  softwaresDe     String?     @map("softwares_de")
  softwaresPara   String?     @map("softwares_para")
  dataAgendamento DateTime?   @map("data_agendamento")
  reagendamentos  String?
  statusEntrega   String?     @default("PENDENTE") @map("status_entrega")
  lembreteEnviado Boolean     @default(false) @map("lembrete_enviado")
  assinatura      String?
  checklistDevolucao String? @map("checklist_devolucao")
  usuario         Usuario     @relation(fields: [usuarioId], references: [id])
  equipamento     Equipamento @relation(fields: [equipamentoId], references: [id])
  tecnico         Usuario?    @relation("TecnicoAtribuicoes", fields: [tecnicoId], references: [id])
  projeto         Projeto?    @relation(fields: [projetoId], references: [id])
  createdAt       DateTime    @default(now()) @map("created_at")

  @@map("vinculacoes")
}

model Historico {
  id            Int         @id @default(autoincrement())
  equipamentoId Int         @map("equipamento_id")
  usuarioId     Int?        @map("usuario_id")
  acao          String
  descricao     String?
  dataInicio    DateTime    @default(now()) @map("data_inicio")
  dataFim       DateTime?   @map("data_fim")
  equipamento   Equipamento @relation(fields: [equipamentoId], references: [id])
  usuario       Usuario?    @relation(fields: [usuarioId], references: [id])
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("historicos")
}

model Chamado {
  id            Int          @id @default(autoincrement())
  titulo        String
  descricao     String?
  status        String       @default("ABERTO")
  prioridade    String?      @default("MEDIA")
  equipamentoId Int?         @map("equipamento_id")
  usuarioId     Int?         @map("usuario_id")
  empresaId     Int?         @map("empresa_id")
  equipamento   Equipamento? @relation(fields: [equipamentoId], references: [id])
  usuario       Usuario?     @relation(fields: [usuarioId], references: [id])
  empresa       Empresa?     @relation(fields: [empresaId], references: [id])
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([empresaId])
  @@map("chamados")
}

model LogAcesso {
  id         Int      @id @default(autoincrement())
  usuarioId  Int?     @map("usuario_id")
  empresaId  Int?     @map("empresa_id")
  projetoId  Int?     @map("projeto_id")
  acao       String
  detalhes   String?
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  projeto    Projeto? @relation(fields: [projetoId], references: [id])

  @@index([empresaId])
  @@index([usuarioId])
  @@index([projetoId])
  @@map("log_acessos")
}

model HistoricoLocalizacao {
  id                Int       @id @default(autoincrement())
  equipamentoId     Int       @map("equipamento_id")
  unidadeAnteriorId Int?      @map("unidade_anterior_id")
  unidadeNovaId     Int?      @map("unidade_nova_id")
  tecnicoId         Int?      @map("tecnico_id")
  createdAt         DateTime  @default(now()) @map("created_at")

  equipamento       Equipamento @relation(fields: [equipamentoId], references: [id])
  unidadeAnterior   Unidade?    @relation("HistoricoLocAnterior", fields: [unidadeAnteriorId], references: [id])
  unidadeNova       Unidade?    @relation("HistoricoLocNova", fields: [unidadeNovaId], references: [id])
  tecnico           Usuario?    @relation(fields: [tecnicoId], references: [id])

  @@map("historico_localizacao")
}

model SolicitacaoAtivo {
  id                        Int       @id @default(autoincrement())

  // Identificação
  numeroChamado             String    @map("numero_chamado")
  dataCriacao               DateTime  @default(now()) @map("data_criacao")
  descricao                 String?
  observacoes               String?

  // Classificação
  tipo                      String
  status                    String    @default("ABERTO")
  estado                    String    @default("Aberto")

  // Etapas do pipeline (datas)
  dataDefinicao             DateTime? @map("data_definicao")
  dataDefinicaoConfirmada   DateTime? @map("data_definicao_confirmada")
  dataSolicitacaoNF         DateTime? @map("data_solicitacao_nf")
  dataEmissaoNF             DateTime? @map("data_emissao_nf")
  dataSolicitacaoColeta     DateTime? @map("data_solicitacao_coleta")
  dataColeta                DateTime? @map("data_coleta")
  previsaoChegada           DateTime? @map("previsao_chegada")
  dataChegada               DateTime? @map("data_chegada")
  dataEntrega               DateTime? @map("data_entrega")

  // Diferença previsão vs real
  diasAtrasoChegada         Int?      @map("dias_atraso_chegada")

  // Ativo
  serialOrigem              String?   @map("serial_origem")
  equipamentoId             Int?      @map("equipamento_id")

  // Relações FK
  tecnicoId                 Int       @map("tecnico_id")
  unidadeId                 Int       @map("unidade_id")
  empresaId                 Int       @map("empresa_id")
  projetoId                 Int?      @map("projeto_id")

  // Controle
  importado                 Boolean   @default(false)
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  // Relações Prisma
  tecnico                   Usuario              @relation("TecnicoSolicitacoes", fields: [tecnicoId], references: [id])
  unidade                   Unidade              @relation(fields: [unidadeId], references: [id])
  empresa                   Empresa              @relation(fields: [empresaId], references: [id])
  projeto                   Projeto?             @relation(fields: [projetoId], references: [id])
  equipamento               Equipamento?         @relation(fields: [equipamentoId], references: [id])
  auditoria                 SolicitacaoAuditoria[]

  @@unique([numeroChamado, empresaId])
  @@index([empresaId])
  @@index([tecnicoId])
  @@index([unidadeId])
  @@index([status])
  @@map("solicitacoes_ativos")
}

model SolicitacaoAuditoria {
  id               Int              @id @default(autoincrement())
  solicitacaoId    Int              @map("solicitacao_id")
  usuarioId        Int?             @map("usuario_id")
  campo            String
  valorAnterior    String?          @map("valor_anterior")
  valorNovo        String?          @map("valor_novo")
  createdAt        DateTime         @default(now()) @map("created_at")

  solicitacao      SolicitacaoAtivo @relation(fields: [solicitacaoId], references: [id])

  @@index([solicitacaoId])
  @@map("solicitacoes_auditoria")
}
